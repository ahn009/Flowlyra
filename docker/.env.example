# Required
SECRET_KEY=change-me-to-a-random-64-char-string
POSTGRES_PASSWORD=change-me

# Stripe billing
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_TEAM_PRICE_ID=price_...
STRIPE_BUSINESS_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# Push notifications (generate with: npx web-push generate-vapid-keys)
PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_PRIVATE_KEY=
PUSH_VAPID_SUBJECT=mailto:support@yourcompany.com

# Monitoring
SENTRY_DSN=

# AI (optional — features degrade gracefully without these)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# OAuth integration credentials (optional — dev mode uses mock tokens without these)
OAUTH_SHOPIFY_CLIENT_ID=
OAUTH_SHOPIFY_CLIENT_SECRET=
OAUTH_SLACK_CLIENT_ID=
OAUTH_SLACK_CLIENT_SECRET=
OAUTH_HUBSPOT_CLIENT_ID=
OAUTH_HUBSPOT_CLIENT_SECRET=
OAUTH_SALESFORCE_CLIENT_ID=
OAUTH_SALESFORCE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# Email
SENDGRID_API_KEY=

# Frontend
API_BASE_URL=/api/v1
VITE_SENTRY_DSN=
VITE_ENVIRONMENT=production
