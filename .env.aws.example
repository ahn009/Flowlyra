# ===============================
# FlowLyra AWS EC2 ENV (PRODUCTION TEMPLATE)
# Copy to: .env
# ===============================

# Database (docker-compose internal service names)
DATABASE_URL=postgresql+asyncpg://cf_user:cf_pass@postgres:5432/chatflow

# Redis (docker-compose internal service names)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Auth
# Use a strong random value (32+ chars)
SECRET_KEY=REPLACE_WITH_A_LONG_RANDOM_SECRET
ACCESS_TOKEN_EXPIRE_MIN=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# App
ENVIRONMENT=production
LOG_LEVEL=INFO
# Replace with your real domain(s) when you add nginx/caddy + HTTPS
# Temporary direct access example:
CORS_ORIGINS=http://YOUR_EC2_PUBLIC_IP:5173,http://YOUR_EC2_PUBLIC_IP:5174
API_BASE_URL=http://YOUR_EC2_PUBLIC_IP:8000
FRONTEND_BASE_URL=http://YOUR_EC2_PUBLIC_IP:5173

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# AWS S3 (optional for file uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=flowlyra-uploads
AWS_REGION=us-east-1

# SendGrid (optional)
SENDGRID_API_KEY=
FROM_EMAIL=hello@flowlyra.com

# Widget CDN URL
CLOUDFLARE_WIDGET_URL=https://cdn.flowlyra.com/widget.js

# Optional integrations
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
WHATSAPP_TOKEN=
META_VERIFY_TOKEN=
