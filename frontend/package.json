{
  "name": "@flowlyra/frontend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "i18n:extract": "node scripts/extract-i18n-keys.mjs",
    "i18n:extract:full": "node scripts/extract-i18n-strings.mjs",
    "perf:budget": "node scripts/dashboard-bundle-budget.mjs",
    "e2e": "playwright test",
    "e2e:mobile": "playwright test --project=\"Mobile Chrome\" --project=\"Mobile Safari\"",
    "a11y:audit": "playwright test e2e/a11y.spec.ts",
    "visual:test": "playwright test e2e/visual.spec.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "5.51.21",
    "axios": "1.7.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "0.468.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hot-toast": "2.4.1",
    "react-router-dom": "6.26.0",
    "react-window": "1.8.10",
    "recharts": "2.12.7",
    "socket.io-client": "4.7.5",
    "tailwind-merge": "^3.5.0",
    "zustand": "4.5.4"
  },
  "devDependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@types/react-window": "1.8.8",
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.55.0",
    "@vitejs/plugin-react": "4.3.1",
    "autoprefixer": "10.4.19",
    "postcss": "8.4.40",
    "tailwindcss": "3.4.7",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "5.5.4",
    "vite": "5.3.5",
    "vitest": "2.0.5"
  }
}
