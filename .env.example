# Database
DATABASE_URL=postgresql+asyncpg://cf_user:cf_pass@postgres:5432/chatflow

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Auth
SECRET_KEY=change-me-to-64-random-chars-in-production
ACCESS_TOKEN_EXPIRE_MIN=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
API_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:5173

# OpenAI - agent reply suggestions only
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=flowlyra-uploads
AWS_REGION=us-east-1

# SendGrid
SENDGRID_API_KEY=
FROM_EMAIL=hello@flowlyra.com

# Widget CDN URL
CLOUDFLARE_WIDGET_URL=https://cdn.flowlyra.com/widget.js

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# WhatsApp
WHATSAPP_TOKEN=
META_VERIFY_TOKEN=

# Push notifications (Phase 13)
PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_PRIVATE_KEY=
PUSH_VAPID_SUBJECT=mailto:hello@flowlyra.com
FCM_SERVER_KEY=
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_PRIVATE_KEY=
APNS_TOPIC=
